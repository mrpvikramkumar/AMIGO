# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string
# Get this from: https://cloud.mongodb.com → Connect → Drivers
# Optional (used only when STORE_FALLBACK=true)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/amigo_db?retryWrites=true&w=majority

# If email is not configured, you can optionally store submissions in MongoDB
STORE_FALLBACK=false

# Email (for contact form notifications)
# Use Gmail App Password (not your regular password)
# Enable: Google Account → Security → 2FA → App Passwords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_FROM_NAME=AMIGO Website
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password-here
EMAIL_TO=amigo@amigointegrators.com

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
# In production: FRONTEND_URL=https://amigointegrators.com
